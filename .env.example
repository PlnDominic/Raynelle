# Public production URL — used for canonical URLs, sitemap, robots, and Open Graph.
NEXT_PUBLIC_SITE_URL=https://www.theraynelleboadu.com

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX).
NEXT_PUBLIC_GA_ID=G-QXJT389959

# Google Search Console verification code.
# Use the "HTML tag" method in Search Console and paste only the value of the
# meta tag's content attribute (not the whole tag) here.
GOOGLE_SITE_VERIFICATION=

# --- Mentorship booking email (nodemailer) ---
# SMTP login. For Gmail / Google Workspace this is the full email address.
SMTP_USER=raynelle@gutsywomenfoundation.org
# App password (NOT the account password). Generate one at
# https://myaccount.google.com/apppasswords and paste it WITHOUT spaces.
SMTP_PASS=
# Where booking requests are delivered (defaults to SMTP_USER's inbox target below).
BOOKING_TO=raynelle@gutsywomenfoundation.org
# SMTP server settings (defaults suit Gmail; port 465 = SSL, 587 = STARTTLS).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
